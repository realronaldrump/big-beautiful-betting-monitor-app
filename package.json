{
  "name": "big-beautiful-betting-monitor-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,auto -c cyan,magenta \"npm:dev:web\" \"npm:worker\"",
    "dev:web": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "concurrently -k -n web,auto -c cyan,magenta \"npm:start:web\" \"npm:worker\"",
    "start:web": "next start --hostname 127.0.0.1",
    "start:container": "concurrently -k -n web,auto -c cyan,magenta \"next start --hostname 0.0.0.0\" \"npm:worker\"",
    "worker": "tsx scripts/automation-worker.ts",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@next/env": "^16.2.10",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.2.4",
    "next": "16.2.10",
    "polymarket-us": "^0.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
